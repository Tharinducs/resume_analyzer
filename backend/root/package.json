{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:api:dev": "node ./scripts/check-node.js && cross-env NODE_ENV=development nodemon index.js services/api/index.js",
    "start:worker:dev": "node ./scripts/check-node.js && cross-env NODE_ENV=development nodemon index.js services/worker/index.js",
    "build:config": "tsc --build packages/config",
    "build:ai": "tsc --build packages/ai",
    "build:shared": "tsc --build packages/shared",
    "build:packages": "npm run build:config && npm run build:ai && npm run build:shared",
    "watch:packages": "tsc --build packages/config packages/ai packages/shared --watch",
    "docker:build": "docker compose up -d --build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.5",
    "bullmq": "^5.69.3",
    "dotenv": "^16.4.0",
    "express": "^4.22.1",
    "form-data": "^4.0.5",
    "groq-sdk": "^0.37.0",
    "ioredis": "^5.9.3",
    "lodash": "^4.17.23",
    "mongoose": "^7.3.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.2.3",
    "cross-env": "^7.0.3",
    "jest": "^25.0.0",
    "nodemon": "^3.1.10",
    "typescript": "^5.9.3"
  }
}
